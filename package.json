{
  "name": "task-cli",
  "version": "1.0.0",
  "description": "CLI task manager — Claude Code course project",
  "main": "dist/index.js",
  "bin": { "task": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "test": "jest --passWithNoTests",
    "test:bun": "bun test __tests__/*.bun.test.ts",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "capstone-check": "node scripts/capstone-check.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0"
  }
}
